# CogArch Environment Variables

# ── LLM API Key ──
OPENAI_API_KEY=your-openai-api-key-here

# ── Model Settings (override defaults from config.yaml) ──
COORDINATOR_MODEL=gpt-4o-mini
SPECIALIST_MODEL=gpt-4o

# ── Data Paths ──
EXPERIENCE_LOG_PATH=./data/experience_log
CHECKPOINT_PATH=./data/checkpoints
BENCHMARK_PATH=./data/benchmarks

# ── Training ──
ENABLE_SLEEP_CYCLE=false
SLEEP_TRIGGER=manual
API_PORT=8080
