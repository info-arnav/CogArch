# CogArch Environment Variables
# Copy this to .env and fill in your values

# ── LLM API Keys ──
OPENAI_API_KEY=sk-proj-...

# Optional (only if using these backends)
ANTHROPIC_API_KEY=sk-ant-...
TOGETHER_API_KEY=...
GROQ_API_KEY=...

# ── Local Model Settings (optional - for Ollama/vLLM) ──
OLLAMA_HOST=http://localhost:11434
VLLM_HOST=http://localhost:8000

# ── Model Settings (override defaults from config.yaml) ──
COORDINATOR_MODEL=gpt-4o-mini
SPECIALIST_MODEL=gpt-4o

# ── Data Paths ──
EXPERIENCE_LOG_PATH=./data/experience_log
CHECKPOINT_PATH=./data/checkpoints
BENCHMARK_PATH=./data/benchmarks

# ── Training ──
ENABLE_SLEEP_CYCLE=false
SLEEP_TRIGGER=manual  # or scheduled or after_n_rounds

# ── API Server ──
API_HOST=0.0.0.0
API_PORT=8080
